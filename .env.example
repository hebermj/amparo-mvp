# ====================================================================
# Amparo MVP v2 — Variáveis de Ambiente (copie para .env e edite)
# cp .env.example .env
# ====================================================================

# ── Canal ──────────────────────────────────────────────────────
# Escolha: telegram | whatsapp | baileys
CANAL=telegram

# ── Telegram (obrigatório se CANAL=telegram) ────────────────────
# Crie um bot grátis em https://t.me/botfather e cole o token:
TELEGRAM_BOT_TOKEN=

# ── WhatsApp Business (obrigatório se CANAL=whatsapp) ──────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_URL=https://graph.facebook.com
WHATSAPP_API_VERSION=v21.0
WHATSAPP_VERIFY_TOKEN=amparo_webhook_verify_2024

# ── LLM Gateway (pelo menos um) ────────────────────────────────
DEEPSEEK_API_KEY=
CLAUDE_API_KEY=
OPENAI_API_KEY=

# ── OpenCode Zen API (compatível com OpenAI) ──────────────────
OPENCODE_ZEN_API_KEY=
OPENCODE_ZEN_BASE_URL=https://opencode.ai/zen/v1
OPENCODE_ZEN_MODEL=deepseek-v4-flash-free

# ── Banco de Dados ─────────────────────────────────────────────
DATABASE_NAME=amparo_mvp
DATABASE_USER=amparo
DATABASE_PASSWORD=amparo123
DATABASE_HOST=localhost
DATABASE_PORT=5432

# ── Redis ──────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── RabbitMQ ───────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# ── SearXNG (meta-buscador) ───────────────────────────────────
SEARXNG_URL=http://localhost:8080

# ── Observabilidade ────────────────────────────────────────────
METRICS_PORT_GATEWAY=3000
METRICS_PORT_TELEGRAM=9095
PROMETHEUS_PORT=9090
LOKI_PORT=3100
TEMPO_PORT=3200
GRAFANA_PORT=3001

# ── Geral ──────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
