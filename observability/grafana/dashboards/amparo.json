{
  "apiVersion": 1,
  "id": 1,
  "title": "Amparo MVP v2 — Dashboard",
  "tags": ["amparo"],
  "timezone": "America/Sao_Paulo",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Mensagens por Worker",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(messages_processed_total) by (service)"
        }
      ],
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Latência p95 (última 1h)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(latency_seconds_bucket[5m])) by (le, service))"
        }
      ],
      "gridPos": { "h": 8, "w": 10, "x": 6, "y": 0 }
    },
    {
      "id": 3,
      "title": "Taxa de Erro (%) por Worker",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * sum(rate(errors_total[5m])) by (service) / sum(rate(messages_processed_total[5m])) by (service)"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 }
    },
    {
      "id": 4,
      "title": "Logs Recentes (Loki)",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service=~\".+\"} |= ``",
          "limit": 100
        }
      ],
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 8 }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "query": "label_values(up, service)"
      }
    ]
  }
}
