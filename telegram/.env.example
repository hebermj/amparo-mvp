# ── Obrigatório ───────────────────────────────────────────────
# Crie um bot com @BotFather e cole o token aqui
TELEGRAM_BOT_TOKEN=

# ── Opcional ──────────────────────────────────────────────────
# Modo de inicialização: polling (padrão, funciona local) ou webhook
TELEGRAM_USE_WEBHOOK=false
# URL pública para webhook (só se USE_WEBHOOK=true)
TELEGRAM_WEBHOOK_URL=

# Restringir o bot a apenas estes chat IDs (separados por vírgula)
# Vazio = aceita qualquer conversa
TELEGRAM_ALLOWED_CHAT_IDS=

# ── RabbitMQ ──────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# ── Portas ────────────────────────────────────────────────────
METRICS_PORT_TELEGRAM=9095
